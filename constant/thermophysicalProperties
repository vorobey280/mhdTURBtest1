FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;

    transport       const;
    thermo          hConst;
    equationOfState Boussinesq;
    specie          specie;

    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   1;
    }
    equationOfState
    {
        rho0        1;
        T0          1;
        beta        1;
    }
    thermodynamics
    {
        Cp          1;
        Hf          1;
    }
    transport
    {
        mu          1;
        Pr          1;
    }
}

