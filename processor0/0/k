FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    inlet
    {
        type            inletOutlet;
        inletValue      uniform 1;
        value           uniform 1;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      nonuniform List<scalar> 0();
        value           nonuniform List<scalar> 0();
    }
    lowerWall
    {
        type            kqRWallFunction;
        value           uniform 1;
    }
    upperWall
    {
        type            kqRWallFunction;
        value           nonuniform List<scalar> 0();
    }
    frontAndBack
    {
        type            kqRWallFunction;
        value           uniform 1;
    }
    procBoundary0to3
    {
        type            processor;
        value           uniform 1;
    }
    procBoundary0to6
    {
        type            processor;
        value           uniform 1;
    }
    procBoundary0to9
    {
        type            processor;
        value           uniform 1;
    }
}


